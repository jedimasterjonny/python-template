{%- set major, minor = python_version.split('.') -%}
[project]
name = "{{ project_slug }}"
version = "0.1.0"
description = "{{ project_description }}"
readme = "README.md"
requires-python = ">={{ python_version }},<{{ major }}.{{ minor | int + 1 }}"
authors = [
    { name = "jedimasterjonny", email = "46541898+jedimasterjonny@users.noreply.github.com" },
]
dependencies = []

[dependency-groups]
dev = []

[tool.uv]
required-version = ">=0.11"
python-preference = "only-managed"
package = true
prerelease = "disallow"
compile-bytecode = true
default-groups = ["dev"]
environments = [
    "sys_platform == 'darwin'",
    "sys_platform == 'linux'",
]

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["src/{{ package_name }}"]
